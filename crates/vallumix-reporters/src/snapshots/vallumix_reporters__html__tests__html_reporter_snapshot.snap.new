<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vallumix Report — web01</title>
<style>
  :root { --bg:#0f172a; --card:#1e293b; --text:#e2e8f0; --muted:#94a3b8; --pass:#22c55e; --fail:#ef4444; --skip:#eab308; --warn:#f97316; --border:#334155; }
  * { box-sizing:border-box; }
  body { margin:0; font-family: ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial; background:var(--bg); color:var(--text); line-height:1.5; }
  .container { max-width:1100px; margin:0 auto; padding:24px; }
  h1 { margin:0 0 8px; font-size:1.5rem; }
  .subtitle { color:var(--muted); margin-bottom:24px; }
  .summary { display:grid; grid-template-columns: repeat(auto-fit,minmax(140px,1fr)); gap:12px; margin-bottom:24px; }
  .card { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:16px; }
  .card h3 { margin:0 0 6px; font-size:.85rem; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); }
  .card .value { font-size:1.6rem; font-weight:700; }
  .pass { color:var(--pass); }
  .fail { color:var(--fail); }
  .skip { color:var(--skip); }
  .rate { color:var(--warn); }
  table { width:100%; border-collapse:collapse; margin-top:12px; }
  th, td { text-align:left; padding:10px 12px; border-bottom:1px solid var(--border); }
  th { font-size:.8rem; text-transform:uppercase; letter-spacing:.04em; color:var(--muted); }
  tr:hover { background:rgba(255,255,255,.03); }
  .badge { display:inline-block; padding:2px 8px; border-radius:999px; font-size:.75rem; font-weight:600; }
  .badge-pass { background:rgba(34,197,94,.15); color:var(--pass); }
  .badge-fail { background:rgba(239,68,68,.15); color:var(--fail); }
  .badge-skip { background:rgba(234,179,8,.15); color:var(--skip); }
  .severity-high { color:var(--fail); font-weight:700; }
  .severity-medium { color:var(--warn); font-weight:700; }
  .severity-low { color:var(--pass); font-weight:700; }
</style>
</head>
<body>
<div class="container">
  <h1>Vallumix Compliance Report</h1>
  <div class="subtitle">web01 &middot; debian/12 &middot; 2024-01-15 12:00:00 +0000</div>

  <div class="summary">
    <div class="card">
      <h3>Total</h3>
      <div class="value">3</div>
    </div>
    <div class="card">
      <h3>Pass</h3>
      <div class="value pass">1</div>
    </div>
    <div class="card">
      <h3>Fail</h3>
      <div class="value fail">1</div>
    </div>
    <div class="card">
      <h3>Skip</h3>
      <div class="value skip">1</div>
    </div>
    <div class="card">
      <h3>Compliance</h3>
      <div class="value rate">33.3%</div>
    </div>
  </div>

  <div class="card">
    <h3 style="margin-top:0">Controls</h3>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Description</th>
          <th>Severity</th>
          <th>Status</th>
          <th>Evidence</th>
        </tr>
      </thead>
      <tbody>
        
        <tr>
          <td>1.1.1.1</td>
          <td>Disable cramfs</td>
          <td class="severity-low">Low</td>
          <td>
            
              <span class="badge badge-pass">Compliant</span>
            
          </td>
          <td>not present</td>
        </tr>
        
        <tr>
          <td>5.2.4</td>
          <td>Disable root login</td>
          <td class="severity-high">High</td>
          <td>
            
              <span class="badge badge-fail">Non-Compliant</span>
            
          </td>
          <td>PermitRootLogin yes</td>
        </tr>
        
        <tr>
          <td>3.1.1</td>
          <td>Disable IP forwarding</td>
          <td class="severity-medium">Medium</td>
          <td>
            
              <span class="badge badge-skip">Skipped</span>
            
          </td>
          <td>dry-run</td>
        </tr>
        
      </tbody>
    </table>
  </div>
</div>
</body>
</html>
